# Claude Code — персональные файлы (не входят в шаблон)
.claude/settings.local.json
.claude/checkpoint.md
.claude/logs/

# Runtime state агента (consent-sentinel'ы WP Gate, пишет create-wp.sh) — issue #250
.claude/state/

# Author-local downstream config for sync-communication-style.py (WP-388)
scripts/sync-communication-style.yaml

# Audit run logs (iwe-audit.sh) — issue #266, previously committed by accident
scripts/*.log

# Backup copies created by skill-promote.sh — local safety net, not for git
